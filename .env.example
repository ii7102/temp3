# Public origin the whole stack should advertise to browsers.
APP_PUBLIC_BASE_URL=http://203.0.113.10

# Host port exposed by the reverse proxy container.
APP_HTTP_PORT=80

# PostgreSQL credentials for the main app database.
POSTGRES_USER=pulsefit
POSTGRES_PASSWORD=pulsefit-password
POSTGRES_DB=pulsefit

# JDBC URL used by Spring Boot to reach PostgreSQL through Docker DNS.
APP_DB_URL=jdbc:postgresql://postgres:5432/pulsefit

# Keycloak bootstrap admin account used for initial login and backend admin API fallback.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-password

# Dedicated database for Keycloak inside the shared PostgreSQL service.
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak-password

# Realm imported on container start.
KEYCLOAK_REALM=pulsefit

# Public OAuth client used by the React frontend.
KEYCLOAK_FRONTEND_CLIENT_ID=pulsefit-frontend

# Confidential OAuth client used by the backend.
KEYCLOAK_BACKEND_CLIENT_ID=pulsefit-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=backend-client-secret

# Stripe secret used by the backend only.
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe publishable key forwarded to the browser runtime config.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook signing secret for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Per-session Stripe price id for a single drop-in class.
STRIPE_PRICE_ID_SESSION=price_session_replace_me

# Monthly Stripe price id for the 10-class pack.
STRIPE_PRICE_ID_CLASS_PACK=price_class_pack_replace_me
